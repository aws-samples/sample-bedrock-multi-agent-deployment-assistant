# AI Deploy Assistant Backend Configuration
# Copy to .env for local development:  cp .env.sample .env
# Then fill in your values below. NEVER commit .env — only .env.sample is tracked.

# ---------------------------------------------------------------------------
# AWS
# ---------------------------------------------------------------------------
AI_DEPLOY_AWS_REGION=us-west-2
# Floci endpoint for local development (routes DynamoDB/S3/SQS to Floci; Bedrock/KB go to real AWS)
# AI_DEPLOY_AWS_ENDPOINT_URL=http://localhost:4566
# AWS profile for real AWS calls (Bedrock + Knowledge Base). Uses ~/.aws/config credentials.
# AI_DEPLOY_AWS_PROFILE=bedrock

# ---------------------------------------------------------------------------
# Bedrock Models
# ---------------------------------------------------------------------------
AI_DEPLOY_PRIMARY_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
AI_DEPLOY_LIGHTWEIGHT_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# Bedrock Token Limits
# AI_DEPLOY_MAX_TOKENS=16384
# AI_DEPLOY_INTERVIEW_MAX_TOKENS=4096
# AI_DEPLOY_INTERVIEW_EXECUTOR_MAX_TOKENS=1024
# AI_DEPLOY_BEDROCK_MAX_CONCURRENCY=10

# IaC Generation Token Limits (per-path overrides)
# AI_DEPLOY_IAC_COMPOSE_MAX_TOKENS=32768
# AI_DEPLOY_IAC_FIX_MAX_TOKENS=32768
# AI_DEPLOY_IAC_LAYER_PLAN_MAX_TOKENS=16384
# AI_DEPLOY_IAC_LAYER_GENERATE_MAX_TOKENS=16384
# AI_DEPLOY_IAC_LAYER_FIX_MAX_TOKENS=16384

# Documentation Agent Token Limits
# AI_DEPLOY_DOCS_DIAGRAM_MAX_TOKENS=16384
# AI_DEPLOY_DOCS_DIAGRAM_FIX_MAX_TOKENS=16384
# AI_DEPLOY_DOCS_USER_GUIDE_MAX_TOKENS=32768
# AI_DEPLOY_DOCS_DIAGRAM_MAX_FIX_ATTEMPTS=3

# Bedrock Knowledge Base (required for KB-grounded generation)
AI_DEPLOY_KNOWLEDGE_BASE_ID=

# Bedrock Guardrails (optional — leave blank to disable)
# AI_DEPLOY_GUARDRAIL_ID=
# AI_DEPLOY_GUARDRAIL_VERSION=DRAFT

# ---------------------------------------------------------------------------
# DynamoDB
# ---------------------------------------------------------------------------
AI_DEPLOY_DYNAMODB_TABLE=ai-deploy-table

# ---------------------------------------------------------------------------
# S3
# ---------------------------------------------------------------------------
AI_DEPLOY_S3_ARTIFACTS_BUCKET=ai-deploy-artifacts
AI_DEPLOY_S3_KNOWLEDGE_BASE_BUCKET=ai-deploy-knowledge-base

# ---------------------------------------------------------------------------
# Cognito (optional — leave blank for local dev without auth)
# ---------------------------------------------------------------------------
# AI_DEPLOY_COGNITO_USER_POOL_ID=
# AI_DEPLOY_COGNITO_CLIENT_ID=

# ---------------------------------------------------------------------------
# Async Processing — Design
# When not set, uses local background worker (no SQS needed for local dev)
# ---------------------------------------------------------------------------
# AI_DEPLOY_SQS_DESIGN_QUEUE_URL=

# ---------------------------------------------------------------------------
# Async Processing — IaC
# When not set, uses local background worker (no SQS needed for local dev)
# ---------------------------------------------------------------------------
# AI_DEPLOY_SQS_IAC_QUEUE_URL=

# ---------------------------------------------------------------------------
# Async Processing — Documentation
# When not set, uses local background worker (no SQS needed for local dev)
# ---------------------------------------------------------------------------
# AI_DEPLOY_SQS_DOCS_QUEUE_URL=

# ---------------------------------------------------------------------------
# WebSocket (optional — API Gateway WS URL for production)
# ---------------------------------------------------------------------------
# AI_DEPLOY_WEBSOCKET_URL=

# ---------------------------------------------------------------------------
# IaC Validation
# ---------------------------------------------------------------------------
# Checkov check IDs to skip (JSON array, e.g., ["CKV_AWS_23"])
# AI_DEPLOY_CHECKOV_SKIP_CHECKS=[]
# Path to cfn-guard binary (bundled in Docker for Lambda)
# AI_DEPLOY_CFN_GUARD_BINARY=cfn-guard

# ---------------------------------------------------------------------------
# Metrics
# ---------------------------------------------------------------------------
# AI_DEPLOY_METRICS_ENABLED=true


# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
AI_DEPLOY_HOST=0.0.0.0
AI_DEPLOY_PORT=8000
# Set to true ONLY for local development
AI_DEPLOY_DEBUG=false
# AI_DEPLOY_CORS_ORIGINS=["http://localhost:3000"]
