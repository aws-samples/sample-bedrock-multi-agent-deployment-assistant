# AI-LCM Backend Configuration
# Copy to .env for local development:  cp .env.sample .env
# Then fill in your values below. NEVER commit .env — only .env.sample is tracked.

# ---------------------------------------------------------------------------
# AWS
# ---------------------------------------------------------------------------
AI_LCM_AWS_REGION=us-east-2

# ---------------------------------------------------------------------------
# Bedrock Models
# ---------------------------------------------------------------------------
AI_LCM_PRIMARY_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
AI_LCM_LIGHTWEIGHT_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# Bedrock Token Limits
# AI_LCM_MAX_TOKENS=16384
# AI_LCM_INTERVIEW_MAX_TOKENS=4096
# AI_LCM_BEDROCK_MAX_CONCURRENCY=6

# IaC Generation Token Limits (per-path overrides)
# AI_LCM_IAC_PARAMETERIZE_MAX_TOKENS=32768
# AI_LCM_IAC_COMPOSE_MAX_TOKENS=32768
# AI_LCM_IAC_GENERATE_MAX_TOKENS=32768
# AI_LCM_IAC_FIX_MAX_TOKENS=32768

# Documentation Agent Token Limits
# AI_LCM_DOCS_DIAGRAM_MAX_TOKENS=16384
# AI_LCM_DOCS_DIAGRAM_FIX_MAX_TOKENS=16384
# AI_LCM_DOCS_USER_GUIDE_MAX_TOKENS=8192
# AI_LCM_DOCS_THREAT_MODEL_MAX_TOKENS=8192
# AI_LCM_DOCS_DIAGRAM_MAX_FIX_ATTEMPTS=3

# Bedrock Knowledge Base (required for KB-grounded generation)
AI_LCM_KNOWLEDGE_BASE_ID=

# Bedrock Guardrails (optional — leave blank to disable)
# AI_LCM_GUARDRAIL_ID=
# AI_LCM_GUARDRAIL_VERSION=DRAFT

# ---------------------------------------------------------------------------
# DynamoDB
# ---------------------------------------------------------------------------
AI_LCM_DYNAMODB_TABLE=ai-lcm-table

# ---------------------------------------------------------------------------
# S3
# ---------------------------------------------------------------------------
AI_LCM_S3_ARTIFACTS_BUCKET=ai-lcm-artifacts
AI_LCM_S3_KNOWLEDGE_BASE_BUCKET=ai-lcm-knowledge-base

# ---------------------------------------------------------------------------
# Cognito (optional — leave blank for local dev without auth)
# ---------------------------------------------------------------------------
# AI_LCM_COGNITO_USER_POOL_ID=
# AI_LCM_COGNITO_CLIENT_ID=

# ---------------------------------------------------------------------------
# Async Processing — Design
# When not set, uses local background worker (no SQS needed for local dev)
# ---------------------------------------------------------------------------
# AI_LCM_SQS_DESIGN_QUEUE_URL=

# ---------------------------------------------------------------------------
# Async Processing — IaC
# When not set, uses local background worker (no SQS needed for local dev)
# ---------------------------------------------------------------------------
# AI_LCM_SQS_IAC_QUEUE_URL=

# ---------------------------------------------------------------------------
# Async Processing — Documentation
# When not set, uses local background worker (no SQS needed for local dev)
# ---------------------------------------------------------------------------
# AI_LCM_SQS_DOCS_QUEUE_URL=

# ---------------------------------------------------------------------------
# WebSocket (optional — API Gateway WS URL for production)
# ---------------------------------------------------------------------------
# AI_LCM_WEBSOCKET_URL=

# ---------------------------------------------------------------------------
# IaC Validation
# ---------------------------------------------------------------------------
# Checkov check IDs to skip (JSON array, e.g., ["CKV_AWS_23"])
# AI_LCM_CHECKOV_SKIP_CHECKS=[]
# Path to cfn-guard binary (bundled in Docker for Lambda)
# AI_LCM_CFN_GUARD_BINARY=cfn-guard

# ---------------------------------------------------------------------------
# Metrics
# ---------------------------------------------------------------------------
# AI_LCM_METRICS_ENABLED=true

# ---------------------------------------------------------------------------
# Storage Backend — "local" for file-based dev, "aws" for DynamoDB+S3
# ---------------------------------------------------------------------------
AI_LCM_STORAGE_BACKEND=local

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
AI_LCM_HOST=0.0.0.0
AI_LCM_PORT=8000
# Set to true ONLY for local development
AI_LCM_DEBUG=false
# AI_LCM_CORS_ORIGINS=["http://localhost:3000"]
